# ─── Birdie KPI Dashboard · Variables de entorno ───────────────────────────
#
# Copia este archivo como .env y llena los valores.
# En Render: añade estas variables en Environment → Add Environment Variable

# URL del Google Apps Script Web App que expone los datos del Sheet
# Ver instrucciones en README.md → sección "Conexión con Google Sheets"
SHEETS_WEBAPP_URL=

# Opcional: API key simple para proteger el endpoint /api/data
# Si se define, el frontend debe enviar header: X-API-Key: <valor>
# API_KEY=tu_clave_secreta_aqui
